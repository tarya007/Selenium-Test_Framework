*.class

# Maven build folder
/target/

# Packaged files
*.jar
*.war
*.ear

#########################################################
# IDE Files
#########################################################

# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/

# VS Code
.vscode/

#########################################################
# Logs
#########################################################

*.log
logs/

#########################################################
# Test Reports
#########################################################

test-output/
allure-results/
allure-report/
reports/
ExtentReport/
screenshots/

#########################################################
# Temporary Files
#########################################################

*.tmp
*.temp
*.swp
*.bak
*.orig

#########################################################
# Operating System Files
#########################################################

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

#########################################################
