#########################################################

.m2/

#########################################################
# Environment Files
#########################################################

.env
.env.*

#########################################################
# Do NOT Ignore These
#########################################################

# Keep Maven Wrapper files in Git
!.mvn/
!mvnw
!mvnw.cmd

# Keep Maven configuration
!pom.xml

# Keep source code
!src/

# Keep README
!README.md
